# Optional shared-state protection. Prefer reverse-proxy SSO or a private network.
# When set, browsers must provide the same value through sessionStorage key
# `autocubes-sync-token` before opening Studio.
STUDIO_SYNC_TOKEN=

# Server-side OpenAI Responses API. Never expose these values through VITE_*.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
OPENAI_ASSISTANT_INSTRUCTIONS=Answer clearly and concisely. Use the user's language.

# Required Bearer token for callers of POST /api/assistant.
# Generate a long random value and keep it private.
ASSISTANT_API_TOKEN=
