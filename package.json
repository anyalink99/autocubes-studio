{
  "name": "autocubes-studio",
  "version": "0.5.0",
  "private": true,
  "scripts": {
    "runtime:ensure": "tsx tooling/scripts/ensure-runtime-data.ts",
    "assistant:chat": "powershell -NoProfile -ExecutionPolicy Bypass -File tooling/scripts/chat.ps1",
    "predev": "npm run runtime:ensure",
    "prestudio": "npm run runtime:ensure",
    "preeditor": "npm run runtime:ensure",
    "prebuild": "npm run runtime:ensure",
    "pretypecheck": "npm run runtime:ensure",
    "precapture:editor": "npm run runtime:ensure",
    "prevideo:check": "npm run runtime:ensure",
    "sfx:generate": "tsx tooling/scripts/generate-sfx.ts",
    "audio:previews": "tsx tooling/scripts/build-audio-previews.ts",
    "dev": "vite --config vite.config.ts --open /",
    "studio": "vite --config vite.config.ts --open /",
    "editor": "vite --config vite.config.ts --open /editor.html",
    "build": "vite build --config vite.config.ts",
    "serve:shared": "vite preview --config vite.config.ts --host 0.0.0.0 --port 4178",
    "browsers:install": "playwright install chromium",
    "editor:build": "vite build --config vite.config.ts",
    "capture:editor": "tsx tooling/capture/run-editor-project.ts data/projects/flowline.editor.json",
    "capture:actions": "tsx tooling/scripts/recommend-capture-actions.ts",
    "render:editor": "remotion render packages/video/index.ts EditorReel out/editor-reel.mp4 --codec=h264 --pixel-format=yuv420p",
    "capture:flowline": "tsx tooling/capture/run.ts flowline",
    "render:flowline": "remotion render packages/video/index.ts FlowlineReel out/flowline-reel.mp4 --codec=h264 --pixel-format=yuv420p",
    "still:flowline": "remotion still packages/video/index.ts FlowlineReel out/flowline-preview.png --frame=150",
    "make:flowline": "npm run capture:flowline && npm run qa:capture:flowline && npm run render:flowline && npm run qa:render:flowline",
    "remotion:studio": "remotion studio packages/video/index.ts",
    "typecheck": "tsc --noEmit",
    "qa:smoke": "tsx tooling/qa/studio-smoke.ts",
    "qa:identity": "tsx tooling/qa/identity-stress.ts",
    "qa:workflows": "tsx tooling/qa/studio-workflows.ts",
    "qa:operations": "tsx tooling/qa/operations-smoke.ts",
    "qa:sync": "tsx tooling/qa/sync-smoke.ts",
    "qa:motion": "tsx tooling/qa/motion-kinematics.ts",
    "qa:capture:flowline": "tsx tooling/qa/video-cadence.ts flowline",
    "qa:render:flowline": "tsx tooling/qa/video-cadence.ts --video out/flowline-reel.mp4 --fps 30 --allow-static",
    "qa:assistant": "tsx tooling/qa/assistant-api.ts",
    "video:check": "remotion compositions packages/video/index.ts",
    "check": "npm run typecheck && npm run build && npm run qa:motion && npm run qa:assistant && npm run qa:smoke && npm run qa:identity && npm run qa:workflows && npm run qa:operations && npm run video:check"
  },
  "dependencies": {
    "@remotion/cli": "4.0.486",
    "@vitejs/plugin-react": "^4.3.4",
    "html-to-image": "^1.11.13",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "openai": "^6.46.0",
    "playwright": "^1.61.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.486",
    "tsx": "4.20.3",
    "vite": "^6.4.3"
  },
  "devDependencies": {
    "@types/node": "20.19.9",
    "@types/react": "18.3.23",
    "@types/react-dom": "18.3.7",
    "typescript": "5.9.3"
  }
}
